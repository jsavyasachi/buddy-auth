{:deps
 {buddy/buddy-sign {:mvn/version "3.6.1-359"}
  clout/clout {:mvn/version "2.2.1"}}
 ;; jose-clj is an OPTIONAL dependency, required only by the `jwks` backend
 ;; (buddy.auth.backends/jwks). It is not pulled into your runtime unless you
 ;; add it yourself, so users who do not need JWKS/OIDC validation are not
 ;; forced to carry Nimbus JOSE+JWT. See the user guide, "JWKS" section.
 :paths ["src" "resources" "target/classes"]
 :aliases
 {:dev
  {:extra-deps
   {org.clojure/clojure {:mvn/version "1.12.1"}
    org.clojure/tools.namespace {:mvn/version "1.5.1"}
    org.clojure/test.check {:mvn/version "1.1.3"}
    net.clojars.savya/jose-clj {:mvn/version "0.2.0"}
    com.bhauman/rebel-readline {:mvn/version "0.1.11"}
    criterium/criterium {:mvn/version "0.4.6"}}
   :extra-paths ["test" "dev"]}

  :test
  {:extra-paths ["test"]
   :extra-deps
   {net.clojars.savya/jose-clj {:mvn/version "0.2.0"}
    io.github.cognitect-labs/test-runner
    {:git/tag "v0.5.1" :git/sha "5e91ee0989d93115cfb5e15b6f242f5ec7ab762e"}}
   :exec-fn cognitect.test-runner.api/test
   :exec-args {:patterns [".*-tests.*"]}}

  ;; CI matrix: clojure -M:1.11:test / clojure -X:1.12:test
  :1.11 {:override-deps {org.clojure/clojure {:mvn/version "1.11.4"}}}
  :1.12 {:override-deps {org.clojure/clojure {:mvn/version "1.12.1"}}}

  :codox
  {:extra-deps
   {codox/codox {:mvn/version "0.10.8"}
    org.clojure/tools.reader {:mvn/version "1.6.0"}
    codox-theme-rdash/codox-theme-rdash {:mvn/version "0.1.2"}}}

  :build
  {:extra-deps {io.github.clojure/tools.build {:git/tag "v0.10.14" :git/sha "9d08b2a1c8a81d8d147d71d13710a34d7d07d7c7"}}
   :ns-default build}

  ;; isolated so deps-deploy's maven stack can't clash with tools.build's
  :deploy
  {:replace-deps {slipset/deps-deploy {:mvn/version "0.2.5"}}
   :exec-fn deps-deploy.deps-deploy/deploy
   :exec-args {:installer :remote
               :artifact "target/buddy-auth-3.2.1.jar"
               :pom-file "target/classes/META-INF/maven/net.clojars.savya/buddy-auth/pom.xml"}}

  :outdated
  {:extra-deps {com.github.liquidz/antq {:mvn/version "RELEASE"}
                org.slf4j/slf4j-nop {:mvn/version "RELEASE"}}
   :main-opts ["-m" "antq.core"]}}}
